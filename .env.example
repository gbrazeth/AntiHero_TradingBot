# ── Server ─────────────────────────────────────
PORT=3333
NODE_ENV=development

# ── Webhook Authentication ─────────────────────
WEBHOOK_TOKEN=change-me-to-a-strong-random-token

# ── Database ───────────────────────────────────
DATABASE_URL="postgresql://user:password@hostname:5432/dbname"

# ── Binance Testnet API (MVP Current Setup) ────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Bybit Protocol (Future) ────────────────────
# The architecture supports dynamic adapters if needed later

# ── Telegram Notifications ────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Trading Parameters (from spec) ────────────
SL_PCT=0.01
TP1_PCT=0.02
TP2_PCT=0.05
BE_BUFFER=0.0005
DAILY_DD_LIMIT=0.04
CAP_EXPOSURE_PCT=0.10
QTY_MODE=fixed_usdt
QTY_VALUE_USDT=50
MIN_REMAINING_POSITION_PCT=0.10
