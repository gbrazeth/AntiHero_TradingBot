# ── Server ─────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Webhook Authentication ─────────────────────
WEBHOOK_TOKEN=change-me-to-a-strong-random-token

# ── Database ───────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Bybit Testnet API ─────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api-testnet.bybit.com

# ── Telegram Notifications ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading Parameters (from spec) ────────────
SL_PCT=0.01
BE_BUFFER=0.0005
DAILY_DD_LIMIT=0.04
CAP_EXPOSURE_PCT=0.10
QTY_MODE=fixed_usdt
QTY_VALUE_USDT=50
MIN_REMAINING_POSITION_PCT=0.10
