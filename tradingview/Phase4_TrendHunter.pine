//@version=6
indicator("AntiHero Bot - Phase 4 (Trend Hunter)", overlay=true)

// =========================================================================
// 1. Webhook Settings
// =========================================================================
var string GRP_WH = "Webhook Setup"
strategyId = input.string("ANTIHERO_PHASE_4", title="Strategy ID", group=GRP_WH)
exchange = input.string("BINANCE_TESTNET", title="Exchange", group=GRP_WH)
timeframeInput = input.string("60", title="Timeframe (Minutes)", group=GRP_WH)

// =========================================================================
// 2. Trend Settings
// =========================================================================
var string GRP_TREND = "Trend Settings"
shortMaLength = input.int(9, title="Short MA Length (SMA)", group=GRP_TREND)
longMaLength = input.int(250, title="Long MA Length (WMA)", group=GRP_TREND)

// =========================================================================
// 3. Logic
// =========================================================================
shortMa = ta.sma(close, shortMaLength)
longMa = ta.wma(close, longMaLength)

buySignal = ta.crossover(shortMa, longMa)
sellSignal = ta.crossunder(shortMa, longMa)

plot(shortMa, color=color.new(color.blue, 0), title="Short SMA")
plot(longMa, color=color.new(color.yellow, 0), title="Long WMA", linewidth=2)

// =========================================================================
// 4. Alerts
// =========================================================================
getJson(event) =>
    '{"strategy_id": "' + strategyId + '","exchange":"' + exchange + '","symbol":"' + syminfo.ticker + '","timeframe":"' + timeframeInput + '","event":"' + event + '","price":' + str.tostring(close) + ',"timestamp":"' + str.format("{0,date,yyyy-MM-dd'T'HH:mm:ssZ}", time) + '"}'

if buySignal
    alert(getJson("TREND_ENTRY_LONG"), alert.freq_once_per_bar)

if sellSignal
    alert(getJson("TREND_ENTRY_SHORT"), alert.freq_once_per_bar)

// Plot
plotshape(buySignal, title="LONG", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), text="LONG", textcolor=color.white, size=size.small)
plotshape(sellSignal, title="SHORT", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="SHORT", textcolor=color.white, size=size.small)
